---
import { site } from '../data/site';

interface Props {
  title?: string;
}
const { title = '' } = Astro.props;
---

<header class="site-header" id="site-header">
  <div class="site-header-inner">
    <a href={import.meta.env.BASE_URL} class="site-header-name">{site.name}</a>
    <div class="site-header-right">
      <span class="site-header-title" id="site-header-title">{title}</span>
      <button class="theme-toggle" id="site-header-toggle" aria-label="Toggle theme">
        <span class="theme-toggle-track">
          <span class="theme-toggle-dot"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    background: var(--paper);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
    padding-top: env(safe-area-inset-top, 0px);
  }

  .site-header.has-border {
    border-bottom-color: var(--border);
  }

  .site-header-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--sp-snug) 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header-name {
    font-family: var(--font-pixel);
    font-size: var(--type-base);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-header-name:hover {
    color: var(--spot);
  }

  .site-header-right {
    display: flex;
    align-items: center;
    gap: var(--sp-element);
  }

  .site-header-title {
    font-family: var(--font-pixel);
    font-size: var(--type-xs);
    letter-spacing: 0.08em;
    color: var(--muted);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease 0.1s, color 0.15s;
  }
  .site-header.title-visible .site-header-title {
    opacity: 1;
    pointer-events: auto;
  }
  .site-header-title:hover {
    color: var(--spot);
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: center;
  }

  .theme-toggle-track {
    width: 28px;
    height: 14px;
    border-radius: 7px;
    border: 1.5px solid var(--border);
    position: relative;
    display: block;
  }

  .theme-toggle-dot {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--spot);
    transition: left 0.2s ease;
  }

  html[data-theme="dark"] .theme-toggle-dot {
    left: 14.5px;
    background: var(--spot);
  }

</style>

<script>
  (function() {
    const stickyHeader = document.getElementById('site-header');
    const pageHeader = document.querySelector('.page-header');
    const stickyTitle = document.getElementById('site-header-title');
    const stickyToggle = document.getElementById('site-header-toggle');

    function update() {
      if (!stickyHeader) return;
      stickyHeader.classList.toggle('has-border', window.scrollY > 5);
      if (pageHeader) {
        const threshold = stickyHeader.offsetHeight;
        stickyHeader.classList.toggle('title-visible', pageHeader.getBoundingClientRect().bottom < threshold);
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('pageshow', (e) => { if ((e as PageTransitionEvent).persisted) update(); });
    update();

    stickyTitle?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    stickyToggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  })();
</script>

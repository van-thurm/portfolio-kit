---
import { site } from '../data/site';

interface Props {
  title?: string;
}
const { title = '' } = Astro.props;
---

<header class="site-header" id="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-header-name">{site.name}</a>
    <div class="site-header-right">
      <span class="site-header-title" id="site-header-title">{title}</span>
      <button class="site-header-toggle" id="site-header-toggle" aria-label="Toggle theme">
        <span class="toggle-opt toggle-opt--sun">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <circle cx="8" cy="8" r="2.5"/>
            <line x1="8" y1="1" x2="8" y2="3"/>
            <line x1="8" y1="13" x2="8" y2="15"/>
            <line x1="1" y1="8" x2="3" y2="8"/>
            <line x1="13" y1="8" x2="15" y2="8"/>
            <line x1="3.1" y1="3.1" x2="4.5" y2="4.5"/>
            <line x1="11.5" y1="11.5" x2="12.9" y2="12.9"/>
            <line x1="3.1" y1="12.9" x2="4.5" y2="11.5"/>
            <line x1="11.5" y1="4.5" x2="12.9" y2="3.1"/>
          </svg>
        </span>
        <span class="toggle-opt toggle-opt--moon">
          <svg viewBox="0 0 16 16" fill="currentColor">
            <path d="M14 8.5A6 6 0 1 1 7.5 2a4.7 4.7 0 0 0 6.5 6.5z"/>
            <circle cx="11.5" cy="3" r="0.7"/>
            <circle cx="13.5" cy="5.5" r="0.5"/>
          </svg>
        </span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    background: var(--paper);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
    padding-top: env(safe-area-inset-top, 0px);
  }

  .site-header.has-border {
    border-bottom-color: var(--border);
  }

  .site-header-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--sp-snug) 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header-name {
    font-family: var(--font-pixel);
    font-size: var(--type-base);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-header-name:hover {
    color: var(--spot);
  }

  .site-header-right {
    display: flex;
    align-items: center;
    gap: var(--sp-element);
  }

  .site-header-title {
    font-family: var(--font-pixel);
    font-size: var(--type-xs);
    letter-spacing: 0.08em;
    color: var(--muted);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease 0.1s, color 0.15s;
  }
  .site-header.title-visible .site-header-title {
    opacity: 1;
    pointer-events: auto;
  }
  .site-header-title:hover {
    color: var(--spot);
  }

  .site-header-toggle {
    display: flex;
    align-items: center;
    gap: var(--sp-tight);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    user-select: none;
  }

</style>

<script>
  (function() {
    const stickyHeader = document.getElementById('site-header');
    const pageHeader = document.querySelector('.page-header');
    const stickyTitle = document.getElementById('site-header-title');
    const stickyToggle = document.getElementById('site-header-toggle');

    function update() {
      if (!stickyHeader) return;
      stickyHeader.classList.toggle('has-border', window.scrollY > 5);
      if (pageHeader) {
        const threshold = stickyHeader.offsetHeight;
        stickyHeader.classList.toggle('title-visible', pageHeader.getBoundingClientRect().bottom < threshold);
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('pageshow', (e) => { if ((e as PageTransitionEvent).persisted) update(); });
    update();

    stickyTitle?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    stickyToggle?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  })();
</script>

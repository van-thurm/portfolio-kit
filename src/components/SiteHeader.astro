---
import { site } from '../data/site';

interface Props {
  title?: string;
}
const { title = '' } = Astro.props;
---

<header class="site-header" id="site-header">
  <div class="site-header-inner">
    <div class="site-header-brand">
      <a href={import.meta.env.BASE_URL} class="site-header-name">{site.name}</a>
      <a
        href={site.templateSource}
        class="sample-badge"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Get this portfolio template on GitHub (opens in new tab)"
        title="Get this template on GitHub"
      >sample</a>
    </div>
    <div class="site-header-right">
      <span class="site-header-title" id="site-header-title">{title}</span>
      <button class="theme-toggle" id="site-header-toggle" aria-label="Toggle theme">
        <span class="theme-toggle-track">
          <span class="theme-toggle-dot"></span>
        </span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 300;
    background: var(--paper);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s ease;
    padding-top: env(safe-area-inset-top, 0px);
  }

  .site-header.has-border {
    border-bottom-color: var(--border);
  }

  .site-header-inner {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: var(--sp-snug) 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header-brand {
    display: flex;
    align-items: center;
    gap: var(--sp-tight);
    min-width: 0;
  }

  .sample-badge {
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-size: var(--type-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: lowercase;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 3px 8px;
    line-height: 1;
    background: var(--ink-bg-subtle);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .sample-badge:hover {
    color: var(--spot);
    border-color: var(--spot);
    background: var(--spot-bg-subtle);
  }

  .site-header-name {
    font-family: var(--font-heading);
    font-size: var(--type-base);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-header-name:hover {
    color: var(--spot);
  }

  .site-header-right {
    display: flex;
    align-items: center;
    gap: var(--sp-element);
  }

  .site-header-title {
    font-family: var(--font-heading);
    font-size: var(--type-xs);
    letter-spacing: 0.08em;
    color: var(--muted);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease 0.1s, color 0.15s;
  }
  .site-header.title-visible .site-header-title {
    opacity: 1;
    pointer-events: auto;
  }
  .site-header-title:hover {
    color: var(--spot);
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: center;
  }

  .theme-toggle-track {
    width: 28px;
    height: 14px;
    border-radius: 7px;
    border: 1.5px solid var(--border);
    position: relative;
    display: block;
  }

  .theme-toggle-dot {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--spot);
    transition: left 0.2s ease;
  }

  html[data-theme="dark"] .theme-toggle-dot {
    left: 14.5px;
    background: var(--spot);
  }

</style>

<script is:inline data-astro-rerun>
  (function() {
    var stickyHeader = document.getElementById('site-header');
    var pageHeader = document.querySelector('.page-header');
    var stickyTitle = document.getElementById('site-header-title');
    var stickyToggle = document.getElementById('site-header-toggle');

    function update() {
      if (!stickyHeader) return;
      stickyHeader.classList.toggle('has-border', window.scrollY > 5);
      if (pageHeader) {
        var threshold = stickyHeader.offsetHeight;
        stickyHeader.classList.toggle('title-visible', pageHeader.getBoundingClientRect().bottom < threshold);
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('pageshow', function(e) { if (e.persisted) update(); });
    update();

    if (stickyTitle) {
      stickyTitle.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    if (stickyToggle) {
      stickyToggle.addEventListener('click', function() {
        var current = document.documentElement.getAttribute('data-theme') || 'light';
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    }
  })();
</script>

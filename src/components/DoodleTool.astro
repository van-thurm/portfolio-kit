<canvas id="draw-canvas"></canvas>
<div id="sticker-layer"></div>

<div class="draw-indicator">
  <div class="di-main">
    <span class="di-dot" id="di-dot"></span>
    <span id="di-tool">press d for doodle mode</span>
  </div>
  <div class="di-hints" id="di-hints"></div>
</div>

<style>
  #draw-canvas {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
  }
  :global(body.draw-mode) #draw-canvas {
    pointer-events: all;
    cursor: crosshair;
  }
  :global(body.sticker-mode) #draw-canvas {
    cursor: copy;
  }

  #sticker-layer {
    position: fixed;
    inset: 0;
    z-index: 95;
    pointer-events: none;
  }
  #sticker-layer :global(.sticker) {
    position: absolute;
    transform: translate(-50%, -50%);
  }
  #sticker-layer :global(.sticker svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .draw-indicator {
    max-width: var(--content-max);
    margin: var(--sp-section) auto 0;
    padding: 6px 12px;
    margin-left: max(24px, calc((100% - var(--content-max)) / 2));
    pointer-events: none;
    user-select: none;
    background: var(--paper);
    border-radius: 6px;
    border: 1px solid var(--border);
    width: fit-content;
  }
  .di-main {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-pixel);
    font-size: 11px;
    color: var(--ink);
    margin-bottom: 3px;
  }
  .di-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  .di-hints {
    font-family: var(--font-body);
    font-size: var(--type-sm);
    font-weight: 300;
    color: var(--ink);
    opacity: 0.35;
  }

  @media (hover: none) {
    .draw-indicator {
      display: none;
    }
  }
</style>

<script>
  const STICKER_SVGS: Record<string, string> = {
    star: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.26 6.86.94-5 4.64 1.24 6.82L12 17.27l-6 3.39 1.24-6.82-5-4.64 6.86-.94z"/></svg>`,
    heart: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`,
    sparkle: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L13.8 9.2 22 12l-8.2 2.8L12 23l-1.8-8.2L2 12l8.2-2.8Z"/></svg>`,
    flower: `<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="6.5" r="3.2" opacity="0.75"/><circle cx="17.2" cy="10.3" r="3.2" opacity="0.75"/><circle cx="15.2" cy="16.2" r="3.2" opacity="0.75"/><circle cx="8.8" cy="16.2" r="3.2" opacity="0.75"/><circle cx="6.8" cy="10.3" r="3.2" opacity="0.75"/><circle cx="12" cy="12" r="2.2"/></svg>`,
    smiley: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="8.5" cy="10" r="1.2" fill="currentColor" stroke="none"/><circle cx="15.5" cy="10" r="1.2" fill="currentColor" stroke="none"/><path d="M8 15c1.5 2 6.5 2 8 0" stroke-linecap="round"/></svg>`,
  };

  const STICKER_NAMES  = ['star', 'heart', 'sparkle', 'flower', 'smiley'];
  const STICKER_LABELS = ['\u2605 star', '\u2665 heart', '\u2726 sparkle', '\u273F flower', '\u263A smiley'];
  const COLORS = ['#D95030', '#1A1A1A', '#9B9B9B', '#6B7F3A', '#C8A62C'];
  const PEN_SIZES = [1.5, 2.5, 4];
  const STICKER_SIZES = [14, 20, 28];

  interface Stroke { color: string; size: number; pts: number[][]; }

  let drawMode = false;
  let drawing = false;
  let colorIdx = 0;
  let sizeIdx = 1;
  let stickerIdx = -1;
  let lastX = 0;
  let lastY = 0;
  let strokes: Stroke[] = [];
  let currentStroke: Stroke | null = null;
  let placedStickers: HTMLElement[] = [];

  const canvas = document.getElementById('draw-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const stickerLayer = document.getElementById('sticker-layer')!;
  const diDot = document.getElementById('di-dot') as HTMLElement;
  const diTool = document.getElementById('di-tool') as HTMLElement;
  const diHints = document.getElementById('di-hints') as HTMLElement;

  const dpr = window.devicePixelRatio || 1;

  function sizeCanvas() {
    canvas.width = window.innerWidth * dpr;
    canvas.height = window.innerHeight * dpr;
    canvas.style.width = window.innerWidth + 'px';
    canvas.style.height = window.innerHeight + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    redrawStrokes();
  }

  function redrawStrokes() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const s of strokes) {
      if (!s.pts || s.pts.length < 2) continue;
      ctx.strokeStyle = s.color;
      ctx.lineWidth = s.size;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.beginPath();
      ctx.moveTo(s.pts[0][0], s.pts[0][1]);
      for (let i = 1; i < s.pts.length; i++) ctx.lineTo(s.pts[i][0], s.pts[i][1]);
      ctx.stroke();
    }
  }

  function updateIndicator() {
    if (!drawMode) {
      diDot.style.display = 'none';
      diTool.textContent = 'press d for doodle mode';
      diHints.textContent = '';
      return;
    }
    diDot.style.display = '';
    diDot.style.background = COLORS[colorIdx];
    if (stickerIdx === -1) {
      diTool.textContent = 'pen';
      diHints.textContent = 'esc \u00B7 c clear \u00B7 s stickers \u00B7 1-5 colors \u00B7 [ ] size';
    } else {
      diTool.textContent = STICKER_LABELS[stickerIdx];
      diHints.textContent = 'esc \u00B7 c clear \u00B7 s next \u00B7 p pen \u00B7 1-5 colors';
    }
  }

  function placeSticker(name: string, x: number, y: number, color: string, size: number) {
    const el = document.createElement('div');
    el.className = 'sticker';
    el.style.left = x + 'px';
    el.style.top = y + 'px';
    el.style.width = size + 'px';
    el.style.height = size + 'px';
    el.style.color = color;
    el.innerHTML = STICKER_SVGS[name];
    stickerLayer.appendChild(el);
    placedStickers.push(el);
  }

  canvas.addEventListener('mousedown', (e: MouseEvent) => {
    if (!drawMode) return;
    if (stickerIdx >= 0) {
      placeSticker(STICKER_NAMES[stickerIdx], e.clientX, e.clientY, COLORS[colorIdx], STICKER_SIZES[sizeIdx]);
      return;
    }
    drawing = true;
    currentStroke = { color: COLORS[colorIdx], size: PEN_SIZES[sizeIdx], pts: [[e.clientX, e.clientY]] };
    lastX = e.clientX;
    lastY = e.clientY;
  });

  canvas.addEventListener('mousemove', (e: MouseEvent) => {
    if (!drawing || !currentStroke) return;
    ctx.strokeStyle = currentStroke.color;
    ctx.lineWidth = currentStroke.size;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.beginPath();
    ctx.moveTo(lastX, lastY);
    ctx.lineTo(e.clientX, e.clientY);
    ctx.stroke();
    currentStroke.pts.push([e.clientX, e.clientY]);
    lastX = e.clientX;
    lastY = e.clientY;
  });

  function endStroke() {
    if (drawing && currentStroke && currentStroke.pts.length > 0) {
      strokes.push(currentStroke);
    }
    drawing = false;
    currentStroke = null;
  }
  canvas.addEventListener('mouseup', endStroke);
  canvas.addEventListener('mouseleave', endStroke);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    const tag = (e.target as HTMLElement).tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;

    if (e.key === 'd' && !e.metaKey && !e.ctrlKey) {
      drawMode = !drawMode;
      document.body.classList.toggle('draw-mode', drawMode);
      if (stickerIdx >= 0) document.body.classList.toggle('sticker-mode', drawMode);
      if (!drawMode) { drawing = false; document.body.classList.remove('sticker-mode'); }
      updateIndicator();
      return;
    }

    if (!drawMode) return;

    if (e.key === 'Escape') {
      drawMode = false;
      drawing = false;
      document.body.classList.remove('draw-mode', 'sticker-mode');
      updateIndicator();
      return;
    }

    if (e.key === 'c' && !e.metaKey && !e.ctrlKey) {
      strokes = [];
      currentStroke = null;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      placedStickers.forEach(el => el.remove());
      placedStickers = [];
      return;
    }

    if (e.key === 's' && !e.metaKey && !e.ctrlKey) {
      stickerIdx++;
      if (stickerIdx >= STICKER_NAMES.length) stickerIdx = 0;
      document.body.classList.add('sticker-mode');
      updateIndicator();
      return;
    }

    if (e.key === 'p' && !e.metaKey && !e.ctrlKey) {
      stickerIdx = -1;
      document.body.classList.remove('sticker-mode');
      updateIndicator();
      return;
    }

    if (e.key >= '1' && e.key <= '5') {
      colorIdx = parseInt(e.key) - 1;
      updateIndicator();
      return;
    }

    if (e.key === '[') { sizeIdx = Math.max(0, sizeIdx - 1); return; }
    if (e.key === ']') { sizeIdx = Math.min(PEN_SIZES.length - 1, sizeIdx + 1); return; }
  });

  sizeCanvas();
  updateIndicator();
  window.addEventListener('resize', sizeCanvas);
</script>
